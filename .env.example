# Required: generate with `openssl rand -hex 32`
API_SECRET=keymustbe32byteslongandhexadecimal1234567890abcdef

# Optional: map of named clients to their own secrets (JSON)
# If omitted, API_SECRET is used for all clients
# API_CLIENTS={"preview-app":"secret1","dev-machine":"secret2"}

# Port to listen on
PORT=4242

# Host to bind to (default: 127.0.0.1)
# BIND_HOST=0.0.0.0

# Max time (ms) to wait for claude -p before killing the process
CC_TIMEOUT_MS=60000

# Claude model to use
CC_MODEL=claude-sonnet-4-5

# Max queue depth (default: 10)
# QUEUE_MAX_DEPTH=10

# Timeout for /chat/tools endpoint (default: 120000 = 2 min)
# CC_TOOLS_TIMEOUT_MS=120000

# Path to MCP db-tools server
# MCP_SERVER_PATH=/opt/mcp-db-tools/server.js

#CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000